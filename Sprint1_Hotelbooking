    // 意图识别关键词映射
    private static final Map<Pattern, String> INTENT_MAP = new LinkedHashMap<>();

    static {
        INTENT_MAP.put(Pattern.compile(".*(预订|预定|订房|房价|房间|房型).*"), "预订");
        INTENT_MAP.put(Pattern.compile(".*(取消|退订|退款|变更).*"), "取消");
        INTENT_MAP.put(Pattern.compile(".*(入住|check in|CI).*"), "入住");
        INTENT_MAP.put(Pattern.compile(".*(退房|check out|CO).*"), "退房");
        INTENT_MAP.put(Pattern.compile(".*(餐厅|吃饭|早餐|晚餐|送餐|餐饮).*"), "餐饮");
        INTENT_MAP.put(Pattern.compile(".*(健身房|泳池|游泳|停车|wifi|WiFi|设施).*"), "设施");
        INTENT_MAP.put(Pattern.compile(".*(商城|商店|购买|商品|特产|积分).*"), "商城");
        INTENT_MAP.put(Pattern.compile(".*(优惠|折扣|活动|促销).*"), "优惠");
    }

    // ==================== 核心RAG流程 ====================
    private static String retrieveKnowledge(String query) {
        String intent = "预订"; // 默认意图
        for (Map.Entry<Pattern, String> entry : INTENT_MAP.entrySet()) {
            if (entry.getKey().matcher(query).matches()) {
                intent = entry.getValue();
                break;
            }
        }

        List<String> relevantDocs = KNOWLEDGE_BASE.getOrDefault(intent, Collections.emptyList());
        if (relevantDocs.isEmpty()) {
            // 如果意图没有匹配到具体知识，返回通用欢迎语
            return "您好，我是酒店AI客服。我可以帮您解答预订、入住、服务查询、商城购物等问题。请问有什么可以帮您？";
        }
        return String.join("\n", relevantDocs);
    }

    private static String generateAnswer(String query, String context, Generation generation, String apiKey)
            throws ApiException, NoApiKeyException, InputRequiredException {
        // 构建提示词模板
        String systemPrompt = "你是酒店管理系统的AI客服助手。请基于提供的【知识库内容】回答用户问题。\n" +
                "要求：\n" +
                "1. 回答简洁、友好，不超过150字。\n" +
                "2. 若知识库中无相关信息，请礼貌说明并引导用户联系人工客服。\n" +
                "3. 严禁编造酒店政策或价格。\n\n" +
                "【知识库内容】\n" + context;

        List<Message> messages = new ArrayList<>();
        messages.add(Message.builder().role(Role.SYSTEM.getValue()).content(systemPrompt).build());
        messages.add(Message.builder().role(Role.USER.getValue()).content(query).build());

        GenerationParam param = GenerationParam.builder()
                .model("qwen-max")
                .apiKey(apiKey)
                .messages(messages)
                .maxTokens(500)
                .temperature(0.7f)
                .resultFormat(GenerationParam.ResultFormat.MESSAGE)
                .build();

        GenerationResult result = generation.call(param);
        return result.getOutput().getChoices().get(0).getMessage().getContent();
    }

    // ==================== 控制台交互逻辑 ====================
    private static void printWelcome() {
        System.out.println("\n============================================");
        System.out.println("     欢迎使用酒店管理系统AI客服 (MVP演示版)");
        System.out.println("============================================");
        System.out.println("我可以帮您解答：");
        System.out.println("  1. 酒店预订（房型、价格、取消政策等）");
        System.out.println("  2. 入住咨询（证件、宠物、行李等）");
        System.out.println("  3. 服务查询（餐饮、健身房、停车等）");
        System.out.println("  4. 商城业务（积分、优惠活动等）");
        System.out.println("\n输入 'exit' 或 'quit' 退出对话。");
        System.out.println("--------------------------------------------\n");
    }

    private static void handleUserInput(String input, Generation generation, String apiKey) {
        if (input == null || input.trim().isEmpty()) {
            System.out.println("客服：您好，请告诉我您需要咨询的问题。");
            return;
        }

        // 输入长度限制（防注入）
        if (input.length() > 2000) {
            System.out.println("客服：您输入的内容过长，请精简后重试（不超过2000字符）。");
            return;
        }

        System.out.println("\n[系统] 正在检索知识库...");
        String context = retrieveKnowledge(input);
        System.out.println("[系统] 检索到相关知识点，正在生成回答...\n");

        try {
            String answer = generateAnswer(input, context, generation, apiKey);
            // 模拟打字机效果（控制台流式输出）
            System.out.print("客服：");
            for (char c : answer.toCharArray()) {
                System.out.print(c);
                try {
                    Thread.sleep(15); // 模拟逐字输出
                } catch (InterruptedException e) {
                    Thread.currentThread().interrupt();
                    System.out.print(c);
                }
            }
            System.out.println("\n");
        } catch (ApiException e) {
            System.err.println("客服：抱歉，AI服务暂时不可用（API错误：" + e.getMessage() + "）。请稍后再试或联系人工客服。");
        } catch (NoApiKeyException e) {
            System.err.println("客服：系统配置错误，请联系管理员配置API密钥。");
        } catch (InputRequiredException e) {
            System.err.println("客服：请求参数错误，请重试。");
        }
    }

    // ==================== 主程序入口 ====================
    public static void main(String[] args) {
        // 从环境变量读取API Key（安全实践）
        String apiKey = System.getenv("DASHSCOPE_API_KEY");
        if (apiKey == null || apiKey.isEmpty()) {
            System.err.println("错误：未设置环境变量 DASHSCOPE_API_KEY，请先配置您的阿里百炼API Key。");
            System.err.println("示例（Linux/Mac）：export DASHSCOPE_API_KEY=your-key-here");
            System.err.println("示例（Windows）：set DASHSCOPE_API_KEY=your-key-here");
            return;
        }

        Generation generation = new Generation();
        printWelcome();

        try (Scanner scanner = new Scanner(System.in)) {
            while (true) {
                System.out.print("您：");
                String input = scanner.nextLine().trim();
                if (input.equalsIgnoreCase("exit") || input.equalsIgnoreCase("quit")) {
                    System.out.println("\n客服：感谢您的咨询，祝您生活愉快！再见~\n");
                    break;
                }
                handleUserInput(input, generation, apiKey);
            }
        }
    }
